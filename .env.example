APP_VERSION=0.0.2
DATABASE_URL=postgresql+psycopg://clara:clara@postgres:5432/clara_voiceops
REDIS_URL=redis://redis:6379/0
AI_SCRIPT_ENABLED=true
GEMINI_MODEL=gemini-2.5-flash
GEMINI_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=eleven_turbo_v2_5
DOCTOR_ELEVENLABS_VOICE_ID=
PHARMACIST_ELEVENLABS_VOICE_ID=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
# Public https URL of the API (e.g. ngrok) so Twilio can reach /twilio/* webhooks.
PUBLIC_API_BASE_URL=
# Defaults to ${PUBLIC_API_BASE_URL}/audio when empty.
PUBLIC_AUDIO_BASE_URL=
MAX_CONVERSATION_TURNS=12
AWS_REGION=us-east-1
